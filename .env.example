# Copy this file to `.env` and replace the placeholder values.

GROQ_API_KEY="your-groq-api-key"
MODEL="llama-3.3-70b-versatile"
GEMINI_API_KEY="your-google-ai-studio-gemini-key"
GEMINI_MODEL="gemini-2.5-flash"
AI_PROVIDER_MODE="smart"
AI_NAME="Xyran"
USER_NAME="darkeeidea"

# Optional extra fallback provider (OpenAI-compatible, for example OpenRouter)
FALLBACK_API_KEY="your-fallback-provider-key"
FALLBACK_MODEL="openai/gpt-4o-mini"
FALLBACK_BASE_URL="https://openrouter.ai/api/v1/chat/completions"

# Optional direct news support
NEWS_API_KEY="your-news-api-key"

# Local Ollama — offline / cloud-API-fail fallback (run: ollama serve && ollama pull llama3.2)
OLLAMA_ENABLED="true"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.2"
OLLAMA_VISION_MODEL="llava"
