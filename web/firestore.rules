rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, update, delete: if false;
      allow create: if request.auth != null && request.auth.uid == userId;

      match /chats/{chatId} {
        allow read, update, delete: if false;
        allow create: if request.auth != null && request.auth.uid == userId;

        match /messages/{messageId} {
          allow read, update, delete: if false;
          allow create: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
  }
}
