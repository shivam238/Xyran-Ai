# Pick one: openrouter | openai | anthropic
PROVIDER=openrouter

# Server
PORT=4321

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Example: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional but recommended by OpenRouter:
OPENROUTER_SITE_URL=http://localhost:4321
OPENROUTER_APP_NAME=Xyran Web

# Firebase Web App config (public client config)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_VERSION=2023-06-01
