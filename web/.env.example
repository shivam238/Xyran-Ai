# Pick one: openrouter | openai | anthropic
PROVIDER=openrouter

# Server
PORT=4321

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=""
# Example: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional but recommended by OpenRouter:
OPENROUTER_SITE_URL=http://localhost:4321
OPENROUTER_APP_NAME=Xyran Web

# Firebase Web App config
FIREBASE_API_KEY=AIzaSyCClyhBsYMxjsDUTk5Igef_Kmivh4xumFw
FIREBASE_AUTH_DOMAIN=xyran-ai.firebaseapp.com
FIREBASE_PROJECT_ID=xyran-ai
FIREBASE_STORAGE_BUCKET=xyran-ai.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=818853265432
FIREBASE_APP_ID=1:818853265432:web:e6c4d30b1ff57b9b70c36d
FIREBASE_MEASUREMENT_ID=G-NE1S788HKK

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
